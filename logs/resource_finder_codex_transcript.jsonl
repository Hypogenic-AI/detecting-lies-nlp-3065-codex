{"type":"item.started","item":{"id":"item_27","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate\npwd\ncat > datasets/.gitignore << 'EOF'\n# Exclude all data files (can be large)\n*\n\n# But include documentation and small samples\n\"'!.gitignore\n!README.md\n!**/README.md\n!**/samples/\n!**/download.sh\n!**/download_instructions.txt\nEOF\npython - << '\"'PY'\nfrom datasets import load_dataset\nfrom pathlib import Path\nimport json\n\nspecs=[\n    ('truthfulqa/truthful_qa', None, 'truthful_qa'),\n    ('pminervini/HaluEval', None, 'halueval'),\n    ('EleutherAI/sycophancy', None, 'sycophancy'),\n    ('notrichardren/deception-evals', None, 'deception_evals'),\n]\n\nbase=Path('datasets')\nbase.mkdir(exist_ok=True)\nreport=[]\n\nfor name,config,outname in specs:\n    target=base/outname\n    status='ok'\n    err=''\n    num_rows={}\n    samples=None\n    try:\n        ds=load_dataset(name, config) if config else load_dataset(name)\n        ds.save_to_disk(str(target))\n        for split,d in ds.items():\n            num_rows[split]=len(d)\n        first_split=next(iter(ds.keys()))\n        sample=ds[first_split].select(range(min(10,len(ds[first_split]))))\n        sdir=target/'samples'\n        sdir.mkdir(parents=True,exist_ok=True)\n        with open(sdir/'samples.json','w') as f:\n            json.dump(sample.to_list(),f,indent=2,ensure_ascii=False)\n    except Exception as e:\n        status='error'\n        err=str(e)\n    report.append({'dataset':name,'out':str(target),'status':status,'rows':num_rows,'error':err})\n\nPath('artifacts/dataset_download_report.json').write_text(json.dumps(report,indent=2))\nprint(json.dumps(report,indent=2))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
