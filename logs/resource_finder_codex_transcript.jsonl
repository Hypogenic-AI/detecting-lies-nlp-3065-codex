{"type":"item.started","item":{"id":"item_21","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate\npwd\npython - << 'PY'\nimport json, os, re, difflib\nimport arxiv\n\nlog=json.load(open('artifacts/paper_download_log.json'))\nmissing=[x for x in log if x['status']\"'!='\"'downloaded']\n\nadded=[]\nfor x in missing:\n    title=x['title']\n    try:\n        search=arxiv.Search(query=f'ti:\\\"{title}\\\"', max_results=3, sort_by=arxiv.SortCriterion.Relevance)\n        results=list(search.results())\n    except Exception:\n        continue\n    if not results:\n        continue\n    best=results[0]\n    sim=difflib.SequenceMatcher(None, title.lower(), best.title.lower()).ratio()\n    if sim < 0.6:\n        continue\n    year=best.published.year if best.published else x.get('year') or 'na'\n    short=re.sub(r'[\"'^a-z0-9]+'\"','_',best.title.lower()).strip('_')[:70]\n    out=f\\\"papers/{year}_{short}.pdf\\\"\n    if os.path.exists(out):\n        continue\n    try:\n        best.download_pdf(filename=out)\n        if os.path.getsize(out) > 5000:\n            x['status']='downloaded_arxiv_fallback'\n            x['file']=out\n            x['pdf_url']=best.pdf_url\n            x['arxiv_id']=best.entry_id.rsplit('/',1)[-1]\n            added.append((title,best.title,out,sim))\n        else:\n            os.remove(out)\n    except Exception:\n        pass\n\nwith open('artifacts/paper_download_log.json','w') as w:\n    json.dump(log,w,indent=2)\n\nprint('fallback_downloaded',len(added))\nfor a in added:\n    print('-',a[0][:70],'=>',a[2],f'sim={a[3]:.2f}')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
